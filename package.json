{
  "name": "promotionsure",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test:unit": "node --test tests/unit",
    "test:unit:coverage": "node scripts/test/runUnitCoverage.mjs",
    "test:db": "supabase test db",
    "test:edge": "node scripts/test/runEdgePaymentIntegration.mjs",
    "test:e2e": "node scripts/test/runPlaywright.mjs",
    "test:e2e:headed": "node scripts/test/runPlaywright.mjs --headed",
    "test:e2e:visual": "node scripts/test/runPlaywright.mjs --visual --project=visual-desktop",
    "test:e2e:performance": "node scripts/test/runPlaywright.mjs --performance --project=performance-desktop",
    "test:load": "node scripts/test/runLoadTest.mjs",
    "test:load:full": "node scripts/test/runLoadTest.mjs --full",
    "test:load:soak": "node scripts/test/runLoadTest.mjs --soak",
    "test:regression": "npm run test:unit && npm run test:db && npm run test:e2e",
    "test:security": "node scripts/test/checkTrackedSecrets.mjs && npm audit --audit-level=high",
    "test:sdet": "npm run lint && npm run build && npm run test:security && npm run test:unit:coverage && npm run test:db && npm run test:edge && npm run test:e2e && npm run test:load:full",
    "import:questions": "node scripts/importQuestions.mjs",
    "content:inspect": "node scripts/content/inspectContent.mjs",
    "content:validate": "node scripts/content/validateContent.mjs",
    "content:build-batch": "node scripts/content/buildBatch.mjs",
    "content:export-import-ready": "node scripts/content/exportImportReady.mjs",
    "content:verify-answer-key": "node scripts/content/verifyAnswerKey.mjs",
    "content:check-import-ready": "node scripts/content/checkImportReady.mjs",
    "content:publish-batch": "node scripts/content/publishBatch.mjs",
    "content:batch-checklist": "node scripts/content/nextBatchChecklist.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "fflate": "^0.8.3",
    "jspdf": "^4.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
