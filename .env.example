# Frontend values are included in the browser bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
# Preferred for production. This is safe in the browser when RLS is enabled.
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Temporary staged-migration fallback for legacy projects.
VITE_SUPABASE_ANON_KEY=your-legacy-supabase-anon-key

# Edge Function secrets. Never use these values in VITE_* variables.
SUPABASE_URL=https://your-project.supabase.co
# Hosted Edge Functions receive SUPABASE_PUBLISHABLE_KEYS and SUPABASE_SECRET_KEYS automatically.
SUPABASE_ANON_KEY=your-legacy-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-legacy-supabase-service-role-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# Public URL used to build the payment callback URL.
APP_URL=https://your-app-domain.example

# Optional Paystack public key for browser-side features.
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
